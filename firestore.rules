rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // RealTime collection - public read (trends visible without login)
    match /RealTime/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Users collection - read for authenticated, write only own document
    match /Users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Reports collection - authenticated users can create, no read/update/delete
    match /Reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // BoardInfo collection - public read (board info & posts visible without login)
    match /BoardInfo/{boardName} {
      allow read: if true;
      allow write: if false;

      // Posts subcollection - public read, auth required for write
      match /Posts/{postId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.UserId == request.auth.uid;
        allow update: if request.auth != null;
        allow delete: if false;

        // BoardPostContents subcollection
        match /BoardPostContents/{contentId} {
          allow read: if true;
          allow create: if request.auth != null;
          allow update, delete: if false;

          // Comments inside BoardPostContents/Comments/CommentList
          match /CommentList/{commentId} {
            allow read: if true;
            allow create: if request.auth != null;
            allow update, delete: if false;
          }
        }
      }
    }

    // Notifications collection - user can read/update own notifications
    match /Notifications/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;

      match /items/{notifId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow create, delete: if false;
      }
    }

    // BoardHotPosts collection - public read
    match /BoardHotPosts/{boardName} {
      allow read: if true;
      allow write: if false;

      match /Posts/{postId} {
        allow read: if true;
        allow write: if false;
      }
    }
  }
}
